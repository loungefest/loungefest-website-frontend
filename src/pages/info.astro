---
import Layout from '../layouts/Layout.astro';
import AccordionItem from '../components/ui/AccordionItem.astro';
import Button from '../components/ui/Button.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/lf-hero.jpg';
import fetchApi from '../lib/strapi';
import { marked } from 'marked';

const renderer = new marked.Renderer();
renderer.link = ({ href, title, text }) =>
    `<a href="${href}"${title ? ` title="${title}"` : ''} target="_blank" rel="noopener noreferrer">${text}</a>`;

type StrapiInfo = {
    title: string;
    description: any;
    priority?: number;
    attributes?: any;
};

interface StrapiGlobal {
    showTicketButton: boolean;
    attributes?: any;
}

const extractText = (blocks: any): string => {
    if (typeof blocks === 'string') return blocks;
    if (Array.isArray(blocks)) {
        return blocks
            .map((block: any) => {
                if (Array.isArray(block?.children)) {
                    return block.children
                        .map((child: any) => child?.text)
                        .filter((text: unknown): text is string => typeof text === 'string')
                        .join('');
                }
                return '';
            })
            .filter((text) => text.length > 0)
            .join('\n\n')
            .trim();
    }
    return '';
};

const rawInfos = await fetchApi<StrapiInfo[]>({
    endpoint: 'infos',
    wrappedByKey: 'data',
    query: {
        'sort[0]': 'priority:asc',
        'sort[1]': 'title:asc',
        'pagination[pageSize]': '100',
    },
});

const globalData = await fetchApi<StrapiGlobal>({
    endpoint: 'global',
    wrappedByKey: 'data',
});

const global = globalData?.attributes ?? globalData;
const showTicketButton = global?.showTicketButton ?? true;

const infos = (await Promise.all(
    (rawInfos ?? []).map(async (item) => {
        const info = item?.attributes ?? item;
        const docId = item?.documentId ?? item?.id ?? '';
        const descriptionText = extractText(info?.description);
        return {
            title: info?.title ?? '',
            description: descriptionText,
            descriptionHtml: await marked.parse(descriptionText, { renderer }),
            id: docId.toString() || (info?.title ?? '').toLowerCase().replace(/[^a-z0-9]+/g, '-'),
        };
    })
)).filter((info) => info.title);

---

<Layout>
    <!-- Hero Section -->
    <section class="relative h-[40vh] min-h-[300px] overflow-hidden">
        <Image
            src={heroImage}
            alt="Informatie Hero"
            class="absolute inset-0 h-full w-full object-cover"
            loading="eager"
        />
        <div class="absolute inset-0 bg-magenta/30 mix-blend-multiply"></div>
        <div class="absolute inset-0 bg-black/20"></div>
    </section>

    <!-- Content Section -->
    <section class="bg-plum py-24 text-white">
        <div class="container mx-auto px-4 max-w-4xl">
            <h1 class="text-center font-display text-5xl sm:text-7xl md:text-9xl font-bold mb-20 tracking-tight text-white">
                Informatie
            </h1>

            <!-- Search -->
            <div class="mb-10">
                <input
                    type="search"
                    id="info-search"
                    aria-label="Zoek in informatie"
                    placeholder="Zoek in informatie..."
                    class="w-full bg-white/10 border border-white/30 rounded-xl px-5 py-4 text-white placeholder-white/40 focus:outline-none focus:border-magenta text-lg transition-colors"
                    autocomplete="off"
                />
            </div>

            <p id="no-results" class="hidden text-center text-white/50 text-lg py-8">
                Geen resultaten gevonden.
            </p>

            <div class="flex flex-col mb-24" id="accordion-list">
                {infos.map((info) => (
                    <div data-info-item data-title={info.title} data-description={info.description}>
                        <AccordionItem title={info.title} id={info.id}>
                            <div class="[&_p]:mb-2 [&_ul]:list-disc [&_ul]:pl-4 [&_ol]:list-decimal [&_ol]:pl-4 [&_strong]:font-bold [&_em]:italic [&_a]:underline [&_a]:hover:text-magenta" set:html={info.descriptionHtml} />
                        </AccordionItem>
                    </div>
                ))}
            </div>

            <!-- "Verkocht?" Section -->
            {showTicketButton && (
                <div class="text-center py-12">
                    <h2 class="font-display text-6xl md:text-8xl font-bold mb-8 text-magenta">
                        Verkocht?
                    </h2>
                    <Button href="/kaarten" variant="outline" size="xl">
                        Kaarten kopen
                    </Button>
                </div>
            )}
        </div>
    </section>
</Layout>

<script>
    function setupSearch() {
        const searchInput = document.getElementById('info-search') as HTMLInputElement | null;
        const items = document.querySelectorAll<HTMLElement>('[data-info-item]');
        const noResults = document.getElementById('no-results');

        if (!searchInput) return;

        searchInput.addEventListener('input', () => {
            const query = searchInput.value.toLowerCase().trim();
            let visibleCount = 0;

            items.forEach((item) => {
                const title = (item.dataset.title ?? '').toLowerCase();
                const description = (item.dataset.description ?? '').toLowerCase();
                const matches = query === '' || title.includes(query) || description.includes(query);

                item.style.display = matches ? '' : 'none';
                if (matches) visibleCount++;
            });

            if (noResults) {
                noResults.classList.toggle('hidden', query === '' || visibleCount > 0);
            }
        });
    }

    setupSearch();
    document.addEventListener('astro:page-load', setupSearch);
</script>
