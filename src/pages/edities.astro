---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import TicketsCTA from '../components/sections/TicketsCTA.astro';
import heroImage from '../assets/images/lf-hero.jpg';
import fetchApi from '../lib/strapi';

type StrapiEditie = {
    title: string;
    youtubeLink: string;
    year: number;
    attributes?: any;
};

const extractYoutubeId = (url: string) => {
    if (!url) return null;
    const match = url.match(/(?:https?:\/\/)?(?:www\.)?(?:youtube\.com\/(?:[^\/\n\s]+\/\S+\/|(?:v|e(?:mbed)?)\/|\S*?[?&]v=)|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
    return match ? match[1] : null;
};

const rawEdities = await fetchApi<StrapiEditie[]>({
    endpoint: 'edities',
    wrappedByKey: 'data',
    query: {
        'sort[0]': 'year:desc',
    },
});

const edities = (rawEdities ?? [])
    .map((item) => {
        const editie = item?.attributes ?? item;
        return {
            title: editie?.title ?? '',
            year: editie?.year ?? '',
            youtubeId: extractYoutubeId(editie?.youtubeLink),
        };
    })
    .filter((editie) => editie.title && editie.youtubeId);
---

<Layout>
    <section class="relative h-[30vh] min-h-[200px] overflow-hidden">
        <Image
            src={heroImage}
            alt="Edities Hero"
            class="absolute inset-0 h-full w-full object-cover"
            loading="eager"
        />
        <div class="absolute inset-0 bg-black/30"></div>
    </section>

    <section class="bg-midnight py-24 text-white min-h-screen">
        <div class="container mx-auto px-4 max-w-6xl">
            <h1 class="text-center font-display text-5xl sm:text-7xl md:text-8xl font-bold mb-20 tracking-tight text-sky">
                Edities
            </h1>

            <div class="edities grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-20">
                {edities.map((editie) => (
                    <div class="editie flex flex-col gap-8">
                        <div class="cookie-embed aspect-video overflow-hidden rounded-[2.5rem] bg-plum-800 shadow-xl border-4 border-sky/20 relative">
                            <div class="cookie-placeholder absolute inset-0 flex flex-col items-center justify-center gap-3 text-white/60 text-sm text-center px-6">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-10 h-10 opacity-40">
                                    <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/>
                                </svg>
                                <span>Accepteer cookies om de video te bekijken.</span>
                            </div>
                            <iframe
                                data-cookie-src={`https://www.youtube.com/embed/${editie.youtubeId}`}
                                title={`${editie.title} (${editie.year})`}
                                class="h-full w-full"
                                style="display:none"
                                frameborder="0"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                referrerpolicy="strict-origin-when-cross-origin"
                                allowfullscreen
                            ></iframe>
                        </div>
                        <div class="flex flex-col gap-1">
                            <h2 class="font-display text-5xl font-bold text-sky leading-none">
                                {editie.title}
                            </h2>
                            <p class="font-display text-3xl font-medium text-white">
                                {editie.year}
                            </p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>
    <TicketsCTA variant="sand" />
</Layout>
