---
import Layout from '../layouts/Layout.astro';

const sponsors = [
    { name: 'Heineken', logo: 'https://placehold.co/400x400?text=Heineken' },
    { name: 'Coca-Cola', logo: 'https://placehold.co/400x400?text=Coca-Cola' },
    { name: 'Red Bull', logo: 'https://placehold.co/400x400?text=Red+Bull' },
    { name: 'Jack Daniels', logo: 'https://placehold.co/400x400?text=Jack+Daniels' },
    { name: 'Lipton', logo: 'https://placehold.co/400x400?text=Lipton' },
    { name: 'Desperados', logo: 'https://placehold.co/400x400?text=Desperados' },
    { name: 'Fuze Tea', logo: 'https://placehold.co/400x400?text=Fuze+Tea' },
    { name: 'Spa', logo: 'https://placehold.co/400x400?text=Spa' },
    { name: 'Brand Bier', logo: 'https://placehold.co/400x400?text=Brand+Bier' },
    { name: 'Grolsch', logo: 'https://placehold.co/400x400?text=Grolsch' },
    { name: 'Chaudfontaine', logo: 'https://placehold.co/400x400?text=Chaudfontaine' },
    { name: 'Texels', logo: 'https://placehold.co/400x400?text=Texels' },
    { name: 'Bax Bier', logo: 'https://placehold.co/400x400?text=Bax+Bier' },
    { name: 'Jopen', logo: 'https://placehold.co/400x400?text=Jopen' },
    { name: 'Brouwerij t IJ', logo: 'https://placehold.co/400x400?text=t+IJ' },
    { name: 'Warsteiner', logo: 'https://placehold.co/400x400?text=Warsteiner' },
];
---

<Layout>
    <section class="relative h-[30vh] min-h-[200px] overflow-hidden">
        <img
            src="/images/lf-hero.jpg"
            alt="Sponsoren Hero"
            class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="absolute inset-0 bg-black/30"></div>
    </section>

    <section class="bg-bronze py-24 text-white min-h-screen">
        <div class="container mx-auto px-4 max-w-6xl">
            <h1 class="text-center font-display text-7xl md:text-8xl font-bold mb-16 tracking-tight text-lime">
                Sponsoren
            </h1>

            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-12 md:gap-x-12 md:gap-y-16">
                {sponsors.map((sponsor) => (
                    <div class="group sponsor-card">
                        <div class="aspect-square overflow-hidden rounded-[2.5rem] mb-6 bg-white shadow-xl flex items-center justify-center p-8 transition-all duration-300 group-hover:shadow-2xl group-hover:scale-105">
                            <img
                                src={sponsor.logo}
                                alt={sponsor.name}
                                class="max-h-full max-w-full object-contain"
                            />
                        </div>
                        <h3 class="font-display text-3xl font-bold text-center text-lime transition-all duration-300 group-hover:scale-110">
                            {sponsor.name}
                        </h3>
                    </div>
                ))}
            </div>
        </div>
    </section>
</Layout>
