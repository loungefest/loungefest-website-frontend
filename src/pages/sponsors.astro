---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import TicketsCTA from '../components/sections/TicketsCTA.astro';
import heroImage from '../assets/images/lf-hero.jpg';
import LavaLamp from "../components/visuals/LavaLamp.astro";
import fetchApi, { getStrapiMedia } from '../lib/strapi';

type StrapiSponsor = {
    name: string;
    priority?: number;
    link?: string;
    image: any;
    attributes?: any;
};

const rawSponsors = await fetchApi<StrapiSponsor[]>({
    endpoint: 'sponsors',
    wrappedByKey: 'data',
    query: {
        'sort[0]': 'priority:desc',
        'sort[1]': 'name:asc',
        populate: '*',
    },
});

const sponsors = (rawSponsors ?? [])
    .map((item) => {
        const sponsor = item?.attributes ?? item;
        const imageMedia = sponsor?.image?.data ?? sponsor?.image;

        return {
            name: sponsor?.name ?? '',
            logo: getStrapiMedia(imageMedia) ?? heroImage.src,
            link: sponsor?.link ?? null,
        };
    })
    .filter((sponsor) => sponsor.name);
---

<Layout>
    <section class="relative h-[30vh] min-h-[200px] overflow-hidden">
        <Image
            src={heroImage}
            alt="Sponsoren Hero"
            class="absolute inset-0 h-full w-full object-cover"
            loading="eager"
        />
        <div class="absolute inset-0 bg-black/30"></div>
    </section>

    <section class="bg-bronze py-24 text-white min-h-screen relative">
        <div class="absolute inset-0 overflow-hidden">
            <LavaLamp color="lime" ballSize={4} numBalls={15} overflow={500} animated={false} responsive={true} />
        </div>
        <div class="container mx-auto px-4 max-w-6xl relative z-10">
            <h1 class="text-center font-display text-5xl sm:text-7xl md:text-8xl font-bold mb-16 tracking-tight text-white">
                Sponsoren
            </h1>

            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-12 md:gap-x-12 md:gap-y-16">
                {sponsors.map((sponsor) => (
                    <div class="group sponsor-card">
                        {sponsor.link ? (
                            <a href={sponsor.link} target="_blank" rel="noopener noreferrer" class="block">
                                <div class="aspect-square overflow-hidden rounded-[2.5rem] mb-6 bg-white shadow-xl flex items-center justify-center p-8 transition-all duration-300 group-hover:shadow-2xl group-hover:scale-105">
                                    <img
                                        src={sponsor.logo}
                                        alt={sponsor.name}
                                        class="max-h-full max-w-full object-contain"
                                    />
                                </div>
                                <h3 class="font-display text-3xl font-bold text-center text-white transition-all duration-300 group-hover:scale-110 truncate">
                                    {sponsor.name}
                                </h3>
                            </a>
                        ) : (
                            <>
                                <div class="aspect-square overflow-hidden rounded-[2.5rem] mb-6 bg-white shadow-xl flex items-center justify-center p-8 transition-all duration-300 group-hover:shadow-2xl group-hover:scale-105">
                                    <img
                                        src={sponsor.logo}
                                        alt={sponsor.name}
                                        class="max-h-full max-w-full object-contain"
                                    />
                                </div>
                                <h3 class="font-display text-3xl font-bold text-center text-white transition-all duration-300 group-hover:scale-110">
                                    {sponsor.name}
                                </h3>
                            </>
                        )}
                    </div>
                ))}
            </div>
        </div>
    </section>
    <TicketsCTA variant="midnight" />
</Layout>
