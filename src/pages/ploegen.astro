---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import TicketsCTA from '../components/sections/TicketsCTA.astro';
import heroImage from '../assets/images/lf-hero.jpg';
import LavaLamp from "../components/visuals/LavaLamp.astro";
import { marked } from 'marked';

import fetchApi, { getStrapiMedia } from '../lib/strapi';

type StrapiPloeg = {
    title: string;
    description: any;
    email?: string;
    image: any;
    attributes?: any;
};

const extractText = (blocks: any): string => {
    if (typeof blocks === 'string') return blocks;
    if (Array.isArray(blocks)) {
        return blocks
            .flatMap((block: any) => (Array.isArray(block?.children)
                ? block.children.map((child: any) => child?.text)
                : []))
            .filter((value: unknown): value is string => typeof value === 'string' && value.trim().length > 0)
            .join(' ')
            .trim();
    }
    return '';
};

const rawPloegen = await fetchApi<StrapiPloeg[]>({
    endpoint: 'ploegen',
    wrappedByKey: 'data',
    query: {
        populate: '*',
        sort: 'title:asc',
        'pagination[pageSize]': '100',
    },
});

const ploegen = (await Promise.all(
    (rawPloegen ?? []).map(async (item) => {
        const ploeg = item?.attributes ?? item;
        const imageMedia = ploeg?.image?.data ?? ploeg?.image;

        return {
            name: ploeg?.title ?? '',
            image: getStrapiMedia(imageMedia) ?? heroImage.src,
            description: await marked.parse(extractText(ploeg?.description)),
            email: ploeg?.email ?? null,
        };
    })
)).filter((ploeg) => ploeg.name);
---

<Layout>
    <section class="relative h-[30vh] min-h-[200px] overflow-hidden">
        <Image
            src={heroImage}
            alt="Ploegen Hero"
            class="absolute inset-0 h-full w-full object-cover"
            loading="eager"
        />
        <div class="absolute inset-0 bg-black/30"></div>
    </section>

    <section class="bg-plum py-24 text-white min-h-screen relative">
        <div class="absolute inset-0 overflow-hidden">
            <LavaLamp color="magenta" ballSize={4} numBalls={15} overflow={500} animated={false} responsive={true} />
        </div>
        <div class="container mx-auto px-4 max-w-6xl relative z-10">
            <h1 class="text-center font-display text-5xl sm:text-7xl md:text-8xl font-bold mb-20 tracking-tight text-white">
                Ploegen
            </h1>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 md:gap-x-12 md:gap-y-20">
                {ploegen.map((ploeg) => (
                    <div class="group ploeg-card relative" tabindex="0">
                        <div class="aspect-square overflow-hidden rounded-[2.5rem] bg-plum-800 shadow-xl relative cursor-pointer mb-6 transition-all duration-300 group-hover:shadow-2xl group-hover:scale-[1.02]">
                            <img
                                src={ploeg.image}
                                alt={ploeg.name}
                                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                            />
                            <div class="ploeg-overlay absolute inset-0 bg-white/50 p-8 flex flex-col justify-center items-center text-center backdrop-blur-md opacity-0 group-hover:opacity-100 transition-all duration-300">
                                {ploeg.description && (
                                    <div class="mb-6 text-plum-900 font-bold text-lg [&_p]:mb-2 [&_ul]:list-disc [&_ul]:pl-4 [&_ol]:list-decimal [&_ol]:pl-4 [&_strong]:font-extrabold [&_em]:italic" set:html={ploeg.description} />
                                )}
                                {ploeg.email && (
                                    <a href={`mailto:${ploeg.email}`} class="text-plum-900 font-bold text-lg underline hover:text-magenta transition-colors">
                                        {ploeg.email}
                                    </a>
                                )}
                            </div>
                        </div>
                        <h2 class="font-display text-3xl font-bold text-center text-white transition-all duration-300 group-hover:scale-110 truncate">
                            {ploeg.name}
                        </h2>
                    </div>
                ))}
            </div>
        </div>
    </section>
    <TicketsCTA variant="sky" />
</Layout>

<style is:global>
    .ploeg-card.active .ploeg-overlay {
        opacity: 1;
    }

    .egg-easter {
        position: absolute;
        left: -48px;
        top: 22%;
        z-index: 0;
        transform: translateX(40px) rotate(30deg);
        transition: transform 0.65s cubic-bezier(0.34, 1.56, 0.64, 1);
        pointer-events: none;
        filter: drop-shadow(3px 5px 10px rgba(0, 0, 0, 0.45));
    }

    .ploeg-card:hover .egg-easter,
    .ploeg-card.active .egg-easter {
        transform: translateX(0px) rotate(-6deg);
    }

    .egg-easter.peek {
        transform: translateX(48px) rotate(15deg);
    }

    .egg-image-z {
        position: relative;
        z-index: 1;
    }
</style>

<script>
    document.querySelectorAll('.ploeg-card').forEach((card) => {
        card.addEventListener('click', (e) => {
            const wasActive = card.classList.contains('active');
            document.querySelectorAll('.ploeg-card').forEach((c) => c.classList.remove('active'));
            if (!wasActive) card.classList.add('active');
            e.stopPropagation();
        });
    });

    document.addEventListener('click', () => {
        document.querySelectorAll('.ploeg-card').forEach((c) => c.classList.remove('active'));
    });

    // 🥚 Paasei: verschijnt vanuit achter een willekeurige ploeg-afbeelding
    const ploegenCards = Array.from(document.querySelectorAll('.ploeg-card'));
    if (ploegenCards.length > 0) {
        const eggCard = ploegenCards[Math.floor(Math.random() * ploegenCards.length)] as HTMLElement;
        const imageContainer = eggCard.querySelector('.aspect-square') as HTMLElement | null;

        if (imageContainer) {
            imageContainer.classList.add('egg-image-z');

            const egg = document.createElement('div');
            egg.className = 'egg-easter';
            egg.setAttribute('aria-hidden', 'true');
            egg.innerHTML = `
                <svg width="68" height="85" viewBox="0 0 68 85" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <ellipse cx="34" cy="46" rx="28" ry="36" fill="#FFE566"/>
                    <path d="M7.5 60 Q34 67 60.5 60 Q58 73 34 79 Q10 73 7.5 60Z" fill="#FF6B9D"/>
                    <path d="M6.5 46 Q34 53 61.5 46 Q61 57 34 63 Q7 57 6.5 46Z" fill="#9B59B6"/>
                    <path d="M7.5 33 Q34 40 60.5 33 Q60 44 34 50 Q8 44 7.5 33Z" fill="#4ECDC4"/>
                    <circle cx="21" cy="38" r="3.2" fill="#FFE566"/>
                    <circle cx="34" cy="36" r="3.2" fill="#FFE566"/>
                    <circle cx="47" cy="38" r="3.2" fill="#FFE566"/>
                    <circle cx="23" cy="66" r="2.8" fill="white" opacity="0.8"/>
                    <circle cx="45" cy="66" r="2.8" fill="white" opacity="0.8"/>
                    <ellipse cx="23" cy="24" rx="6" ry="9" fill="white" opacity="0.28" transform="rotate(-12 23 24)"/>
                </svg>
            `;
            eggCard.appendChild(egg);

            // Na een willekeurige vertraging even heel kort piepen om de hint te geven
            const peekDelay = 20000 + Math.random() * 40000;
            setTimeout(() => {
                if (!eggCard.classList.contains('active') && !eggCard.matches(':hover')) {
                    egg.classList.add('peek');
                    setTimeout(() => egg.classList.remove('peek'), 1800);
                }
            }, peekDelay);
        }
    }
</script>
