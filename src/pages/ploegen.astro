---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import TicketsCTA from '../components/sections/TicketsCTA.astro';
import heroImage from '../assets/images/lf-hero.jpg';

const ploegen = [
    { 
        name: 'Artiesten begeleiding', 
        image: 'https://placehold.co/600x600?text=Artiesten+begeleiding',
        names: ['Maartje', 'Lise', 'Nathalie', 'Nina', 'Roel', 'Roos', 'Michelle', 'Fleur B', 'Guusje', 'Stijn', 'Iris', 'Fleur K', 'Esmee', 'Marjolein'],
        email: 'hospitality@loungefest.nl'
    },
    { 
        name: "Bavo's", 
        image: 'https://placehold.co/600x600?text=Bavo%27s',
        names: ['Sjoerd', 'Twan', 'Luuk', 'Stan', 'Mick', 'Wessel', 'Bas', 'Lars', 'Niels', 'Joris'],
        email: 'bavos@loungefest.nl'
    },
    { 
        name: 'Bouwcrew', 
        image: 'https://placehold.co/600x600?text=Bouwcrew',
        names: ['Gijs', 'Wouter', 'Kevin', 'Sven', 'Thijs', 'Tim', 'Niek', 'Bart', 'Daan', 'Hugo'],
        email: 'bouwcrew@loungefest.nl'
    },
    { 
        name: 'Clawbangers', 
        image: 'https://placehold.co/600x600?text=Clawbangers',
        names: ['Amber', 'Eva', 'Lisa', 'Britt', 'Isa', 'Maud', 'Julia', 'Floor', 'Tess', 'Iris'],
        email: 'clawbangers@loungefest.nl'
    },
    { 
        name: 'Finance', 
        image: 'https://placehold.co/600x600?text=Finance',
        names: ['Mark', 'Sander', 'Tom', 'Jeroen', 'Bas'],
        email: 'finance@loungefest.nl'
    },
    { 
        name: 'Infra', 
        image: 'https://placehold.co/600x600?text=Infra',
        names: ['Rick', 'Stefan', 'Kevin', 'Dennis', 'Nick'],
        email: 'infra@loungefest.nl'
    },
];
---

<Layout>
    <section class="relative h-[30vh] min-h-[200px] overflow-hidden">
        <Image
            src={heroImage}
            alt="Ploegen Hero"
            class="absolute inset-0 h-full w-full object-cover"
            loading="eager"
        />
        <div class="absolute inset-0 bg-black/30"></div>
    </section>

    <section class="bg-plum py-24 text-white min-h-screen">
        <div class="container mx-auto px-4 max-w-6xl">
            <h1 class="text-center font-display text-5xl sm:text-7xl md:text-8xl font-bold mb-20 tracking-tight text-magenta">
                Onze ploegen
            </h1>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 md:gap-x-12 md:gap-y-20">
                {ploegen.map((ploeg) => (
                    <div class="group ploeg-card relative" tabindex="0">
                        <div class="aspect-square overflow-hidden rounded-[2.5rem] bg-plum-800 shadow-xl relative cursor-pointer">
                            <img
                                src={ploeg.image}
                                alt={ploeg.name}
                                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                            />
                            <div class="absolute inset-0 bg-white/90 p-8 flex flex-col justify-center items-center text-center backdrop-blur-md opacity-0 group-hover:opacity-100 group-focus:opacity-100 transition-all duration-300">
                                <h3 class="font-display text-3xl font-bold text-plum-900 mb-4 leading-tight">
                                    {ploeg.name}
                                </h3>
                                {ploeg.names && (
                                    <div class="mb-6 text-plum-900 font-bold text-lg leading-relaxed">
                                        {ploeg.names.join(', ')}
                                    </div>
                                )}
                                {ploeg.email && (
                                    <a href={`mailto:${ploeg.email}`} class="text-plum-900 font-bold text-lg underline hover:text-magenta transition-colors">
                                        {ploeg.email}
                                    </a>
                                )}
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>
    <TicketsCTA variant="sky" />
</Layout>
