---
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
import LavaLamp from '../components/visuals/LavaLamp.astro';
---

<Layout>
    <section class="bg-sand relative overflow-hidden flex-grow flex items-center justify-center py-24 text-plum min-h-[80vh]">
        <div class="absolute inset-0 overflow-hidden pointer-events-none opacity-40">
            <LavaLamp color="lime" ballSize={12} numBalls={30} responsive={true} />
        </div>

        <div class="container mx-auto px-4 max-w-4xl text-center relative z-10">
            <div class="relative inline-block mb-8">
                <h1 class="font-display text-[12rem] md:text-[18rem] font-bold leading-none text-magenta drop-shadow-2xl animate-pulse-slow">
                    404
                </h1>
                <div class="absolute -top-4 -right-4 md:-top-8 md:-right-8 bg-plum text-white font-display font-bold text-xl md:text-2xl px-6 py-2 rounded-full rotate-12 shadow-xl">
                    OEPS!
                </div>
            </div>
            <h2 class="font-display text-4xl md:text-6xl font-bold mb-8 tracking-tight">
                Pagina niet gevonden.
            </h2>
            <p class="text-xl md:text-2xl mb-12 max-w-2xl mx-auto leading-relaxed">
                Het lijkt erop dat de pagina die je zoekt is gaan loungen op een andere plek.
                Geen zorgen, het feestje gaat gewoon door op onze homepagina!
            </p>
            <div class="flex justify-center">
                <Button href="/" variant="plum" size="xl">
                    Terug naar Home
                </Button>
            </div>
        </div>
    </section>

<style>
    @keyframes pulse-slow {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.9; transform: scale(1.02); }
    }
    .animate-pulse-slow {
        animation: pulse-slow 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
</style>
</Layout>
