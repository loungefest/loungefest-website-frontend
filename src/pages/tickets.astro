---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/lf-hero.jpg';
import LoungefestIcon from '../components/logo/LoungefestIcon.astro';
import LavaLamp from "../components/visuals/LavaLamp.astro";
---

<Layout showChatbot={false} showEasterEggs={false} minimal={true}>
    <!-- Content Section -->
    <section class="relative bg-midnight pt-48 pb-24 text-white overflow-hidden grow flex items-center">
        <div class="absolute inset-0 overflow-hidden">
            <LavaLamp color="sky" ballSize={4} numBalls={15} overflow={500} animated={false} responsive={true} />
        </div>

        <!-- Decorative background icon -->
        <div class="absolute opacity-10 pointer-events-none select-none" style="top: -5%; right: -5%; width: 30rem; height: 30rem; transform: rotate(20deg);">
            <LoungefestIcon color="white" class="h-full w-full" />
        </div>

        <div class="container relative z-10 mx-auto px-4 max-w-3xl text-center">
            <h1 class="font-display text-5xl sm:text-7xl md:text-9xl font-bold mb-8 tracking-tight text-white">
                Tickets
            </h1>
            <p class="text-xl md:text-2xl text-white/80 leading-relaxed mb-4">
                De ticketverkoop start binnenkort!
            </p>
            <p class="text-lg text-white/50">
                Houd deze pagina in de gaten voor meer informatie.
            </p>
        </div>
    </section>
</Layout>
