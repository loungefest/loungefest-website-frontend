---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/lf-hero.jpg';
import LoungefestIcon from '../components/logo/LoungefestIcon.astro';
import LavaLamp from "../components/visuals/LavaLamp.astro";
import chunkVendors from '../assets/js/chunk-vendors.b6ec443c.js?url';
import app from '../assets/js/app.66ee4f63.js?url';
---

<Layout showChatbot={false} showEasterEggs={false} minimal={true}>
    <!-- Content Section -->
    <section class="relative bg-sand pt-48 pb-24 text-white overflow-hidden grow flex items-center">
        <div class="absolute inset-0 overflow-hidden">
            <LavaLamp color="lime" ballSize={4} numBalls={15} overflow={500} animated={false} responsive={true} />
        </div>

        <!-- Decorative background icon -->
        <div class="absolute opacity-10 pointer-events-none select-none" style="top: -5%; right: -5%; width: 30rem; height: 30rem; transform: rotate(20deg);">
            <LoungefestIcon color="white" class="h-full w-full" />
        </div>

        <div class="container relative z-10 mx-auto px-4 max-w-6xl text-center">
            <div id="app"></div>
        </div>
    </section>
    <script is:inline src={chunkVendors}></script>
    <script is:inline src={app}></script>
</Layout>
