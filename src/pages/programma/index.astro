---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/ui/Button.astro';
import TicketsCTA from '../../components/sections/TicketsCTA.astro';
import fetchApi, { getStrapiMedia } from '../../lib/strapi';
import { Image } from 'astro:assets';
import heroImage from '../../assets/images/lf-hero.jpg';

type Performance = { datetime?: string; day?: string; time?: string; podium?: any };

type NormalizedPerformance = {
    day: string;
    time: string;
    podium?: string;
};

const dayFormatter = new Intl.DateTimeFormat('nl-NL', {
    weekday: 'long',
    timeZone: 'Europe/Amsterdam',
});

const timeFormatter = new Intl.DateTimeFormat('nl-NL', {
    hour: '2-digit',
    minute: '2-digit',
    hour12: false,
    timeZone: 'Europe/Amsterdam',
});

const capitalize = (value: string) => value.charAt(0).toUpperCase() + value.slice(1);

const normalizePerformance = (performance: Performance, artistPodium?: any): NormalizedPerformance | null => {
    const podiumName =
        performance?.podium?.data?.attributes?.title ||
        performance?.podium?.title ||
        (typeof performance?.podium === 'string' ? performance.podium : null) ||
        artistPodium?.data?.attributes?.title ||
        artistPodium?.title ||
        (typeof artistPodium === 'string' ? artistPodium : null);

    if (typeof performance?.datetime === 'string') {
        const date = new Date(performance.datetime);

        if (!Number.isNaN(date.getTime())) {
            return {
                day: capitalize(dayFormatter.format(date)),
                time: timeFormatter.format(date),
                podium: podiumName,
            };
        }
    }

    if (performance?.day) {
        return {
            day: performance.day,
            time: performance?.time || 't.b.d.',
            podium: podiumName,
        };
    }

    return null;
};

type StrapiArtist = {
    slug?: string;
    name?: string;
    priority?: number;
    image?: any;
    podium?: any;
    performances?: Performance[];
    attributes?: any;
};

type StrapiPodium = {
    title: string;
    attributes?: any;
};

const rawArtists = await fetchApi<StrapiArtist[]>({
    endpoint: 'artists',
    wrappedByKey: 'data',
    query: {
        'sort[0]': 'priority:desc',
        'sort[1]': 'name:asc',
        'populate[0]': 'image',
        'populate[1]': 'podium',
        'populate[2]': 'performances',
    },
});

const rawPodia = await fetchApi<StrapiPodium[]>({
    endpoint: 'podia',
    wrappedByKey: 'data',
    query: {
        'sort[0]': 'title:asc',
    },
});

const podia = (rawPodia ?? [])
    .map((item) => {
        const podium = item?.attributes ?? item;
        return podium.title;
    })
    .filter(Boolean);

const artists = (rawArtists ?? [])
    .map((item) => {
        const artist = item?.attributes ?? item;
        const imageMedia = artist?.image?.data ?? artist?.image;

        const performances = Array.isArray(artist?.performances)
            ? artist.performances
                .map((performance: Performance) => normalizePerformance(performance, artist?.podium))
                .filter((performance): performance is NormalizedPerformance => Boolean(performance))
            : [];

        const days = performances.length
            ? [...new Set(performances.map((performance) => performance.day))]
            : [];

        const artistPodiumName =
            artist?.podium?.data?.attributes?.title ||
            artist?.podium?.title ||
            (typeof artist?.podium === 'string' ? artist.podium : null);

        const artistPodia = performances.length
            ? [...new Set(performances.map((p) => p.podium).filter(Boolean))]
            : artistPodiumName ? [artistPodiumName] : [];

        const scheduleLabel = performances.length
            ? performances
                .map((performance) => {
                    const label = `${performance.day} - ${performance.time}`;
                    return performance.podium ? `${label} - ${performance.podium}` : label;
                })
                .join(' · ')
            : artistPodiumName ? `Tijd volgt - ${artistPodiumName}` : 'Tijd volgt';

        return {
            slug: artist?.slug ?? '',
            name: artist?.name ?? '',
            imageUrl: getStrapiMedia(imageMedia) ?? heroImage.src,
            days,
            podia: artistPodia,
            scheduleLabel,
        };
    })
    .filter((artist) => artist.slug && artist.name);

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<Layout>
    <section class="relative h-[30vh] min-h-[200px] overflow-hidden">
        <Image
            src={heroImage}
            alt="Programma Hero"
            class="absolute inset-0 h-full w-full object-cover"
            loading="eager"
        />
        <div class="absolute inset-0 bg-black/30"></div>
    </section>

    <section class="bg-midnight py-24 text-white min-h-screen">
        <div class="container mx-auto px-4 max-w-6xl">
            <h1 class="text-center font-display text-5xl sm:text-7xl md:text-8xl font-bold mb-16 tracking-tight">
                Programma
            </h1>

            <!-- Day filter -->
            <div class="flex flex-col sm:flex-row justify-center gap-4 mb-8" id="day-filters">
                <Button variant="sky" size="md" data-day="all">Alle dagen</Button>
                <Button variant="outline" size="md" data-day="Vrijdag">Vrijdag</Button>
                <Button variant="outline" size="md" data-day="Zaterdag">Zaterdag</Button>
            </div>

            <!-- Podium filter -->
            <div class="flex flex-wrap justify-center gap-4 mb-20" id="podium-filters">
                <Button variant="magenta" size="md" data-podium="all">Alle podia</Button>
                {podia.map((podium) => (
                    <Button variant="outline" size="md" data-podium={podium}>{podium}</Button>
                ))}
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 md:gap-x-12 md:gap-y-16">
                {artists.map((artist) => (
                    <a
                        href={`${base}programma/${artist.slug}`}
                        class="group artist-card block"
                        data-days={artist.days.join(',')}
                        data-podia={artist.podia.join(',')}
                    >
                        <div class="aspect-square overflow-hidden rounded-[2.5rem] mb-6 bg-plum-800 shadow-xl">
                            <img
                                src={artist.imageUrl}
                                alt={artist.name}
                                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                                loading="lazy"
                            />
                        </div>
                        <h3 class="font-display text-3xl font-bold text-sky mb-1 leading-tight group-hover:text-magenta transition-colors">
                            {artist.name}
                        </h3>
                        <p class="text-xl font-medium text-white/80">
                            {artist.scheduleLabel}
                        </p>
                    </a>
                ))}
            </div>
        </div>
    </section>
    <TicketsCTA variant="lime" />
</Layout>

<script>
    const setupFilters = () => {
        const dayButtons = document.querySelectorAll('#day-filters [data-day]');
        const podiumButtons = document.querySelectorAll('#podium-filters [data-podium]');
        const artistCards = document.querySelectorAll('.artist-card');

        // Classes to swap for button states
        const activeDayClasses = ['bg-sky', 'hover:shadow-sky/20', 'hover:scale-105', 'shadow-xl'];
        const activePodiumClasses = ['bg-magenta', 'hover:shadow-magenta/20', 'hover:scale-105', 'shadow-xl'];
        const inactiveClasses = ['border-2', 'border-white', 'hover:bg-white', 'hover:text-plum'];

        let activeDay = 'all';
        let activePodium = 'all';

        const updateFilters = () => {
            artistCards.forEach(card => {
                const days = (card.getAttribute('data-days') || '')
                    .split(',')
                    .map((d) => d.trim())
                    .filter(Boolean);

                const podia = (card.getAttribute('data-podia') || '')
                    .split(',')
                    .map((p) => p.trim())
                    .filter(Boolean);

                const dayMatch = activeDay === 'all' || days.includes(activeDay);
                const podiumMatch = activePodium === 'all' || podia.includes(activePodium);

                if (dayMatch && podiumMatch) {
                    card.classList.remove('hidden');
                } else {
                    card.classList.add('hidden');
                }
            });
        };

        const updateButtonStyles = (buttons, activeValue, attr, activeClasses) => {
            buttons.forEach(btn => {
                if (btn.getAttribute(attr) === activeValue) {
                    btn.classList.add(...activeClasses);
                    btn.classList.remove(...inactiveClasses);
                } else {
                    btn.classList.remove(...activeClasses);
                    btn.classList.add(...inactiveClasses);
                }
            });
        };

        dayButtons.forEach(button => {
            button.addEventListener('click', () => {
                activeDay = button.getAttribute('data-day');
                updateButtonStyles(dayButtons, activeDay, 'data-day', activeDayClasses);
                updateFilters();
            });
        });

        podiumButtons.forEach(button => {
            button.addEventListener('click', () => {
                activePodium = button.getAttribute('data-podium');
                updateButtonStyles(podiumButtons, activePodium, 'data-podium', activePodiumClasses);
                updateFilters();
            });
        });
    };

    // Run on page load
    document.addEventListener('DOMContentLoaded', setupFilters);
    // Also run on astro:page-load if using View Transitions
    document.addEventListener('astro:page-load', setupFilters);
</script>
