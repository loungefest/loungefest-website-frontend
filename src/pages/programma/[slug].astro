---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/ui/Button.astro';
import TicketsCTA from '../../components/sections/TicketsCTA.astro';
import fetchApi, { getStrapiMedia } from '../../lib/strapi';
import heroImage from '../../assets/images/lf-hero.jpg';

type Performance = { datetime?: string; day?: string; time?: string; podium?: any };

type NormalizedPerformance = {
    day: string;
    time: string;
    podium?: string;
};

type StrapiArtist = {
    slug?: string;
    name?: string;
    day?: string;
    time?: string;
    image?: any;
    podium?: any;
    description?: unknown;
    performances?: Performance[];
    youtubeLink?: string;
    spotifyLink?: string;
    attributes?: any;
};

type ArtistPageData = {
    slug: string;
    name: string;
    imageUrl: string;
    description: string;
    performances: NormalizedPerformance[];
    podium?: string;
    youtubeLink?: string;
    spotifyLink?: string;
};

export async function getStaticPaths() {
    const dayFormatter = new Intl.DateTimeFormat('nl-NL', {
        weekday: 'long',
        timeZone: 'Europe/Amsterdam',
    });

    const timeFormatter = new Intl.DateTimeFormat('nl-NL', {
        hour: '2-digit',
        minute: '2-digit',
        hour12: false,
        timeZone: 'Europe/Amsterdam',
    });

    const capitalize = (value: string) => value.charAt(0).toUpperCase() + value.slice(1);

    const normalizePerformance = (performance: Performance, artistPodium?: any): NormalizedPerformance | null => {
        const podiumName =
            performance?.podium?.data?.attributes?.title ||
            performance?.podium?.title ||
            (typeof performance?.podium === 'string' ? performance.podium : null) ||
            artistPodium?.data?.attributes?.title ||
            artistPodium?.title ||
            (typeof artistPodium === 'string' ? artistPodium : null);

        if (typeof performance?.datetime === 'string') {
            const date = new Date(performance.datetime);

            if (!Number.isNaN(date.getTime())) {
                return {
                    day: capitalize(dayFormatter.format(date)),
                    time: timeFormatter.format(date),
                    podium: podiumName,
                };
            }
        }

        if (performance?.day) {
            return {
                day: performance.day,
                time: performance?.time || 't.b.d.',
                podium: podiumName,
            };
        }

        return null;
    };

    const extractDescription = (description: unknown): string => {
        if (typeof description === 'string') {
            return description;
        }

        if (Array.isArray(description)) {
            const text = description
                .flatMap((block: any) => (Array.isArray(block?.children)
                    ? block.children.map((child: any) => child?.text)
                    : []))
                .filter((value: unknown): value is string => typeof value === 'string' && value.trim().length > 0)
                .join(' ')
                .trim();

            if (text) {
                return text;
            }
        }

        return 'Informatie volgt binnenkort.';
    };

    const rawArtists = await fetchApi<StrapiArtist[]>({
        endpoint: 'artists',
        wrappedByKey: 'data',
        query: {
            'sort[0]': 'priority:desc',
            'sort[1]': 'name:asc',
            'populate[0]': 'image',
            'populate[1]': 'podium',
            'populate[2]': 'performances',
        },
    });

    return (rawArtists ?? [])
        .map((item) => {
            const artist = item?.attributes ?? item;
            const imageMedia = artist?.image?.data ?? artist?.image;

            const artistPodiumName =
                artist?.podium?.data?.attributes?.title ||
                artist?.podium?.title ||
                (typeof artist?.podium === 'string' ? artist.podium : null);

            const performances = Array.isArray(artist?.performances)
                ? artist.performances
                    .map((performance: Performance) => normalizePerformance(performance, artist?.podium))
                    .filter((performance): performance is NormalizedPerformance => Boolean(performance))
                : [];

            const pageArtist: ArtistPageData = {
                slug: artist?.slug ?? '',
                name: artist?.name ?? '',
                imageUrl: getStrapiMedia(imageMedia) ?? heroImage.src,
                description: extractDescription(artist?.description),
                performances,
                podium: artistPodiumName,
                youtubeLink: artist?.youtubeLink,
                spotifyLink: artist?.spotifyLink,
            };

            return {
                params: { slug: pageArtist.slug },
                props: { artist: pageArtist },
            };
        })
        .filter((entry) => entry.params.slug && entry.props.artist.name);
}

const { artist } = Astro.props as { artist: ArtistPageData };

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<Layout>
    <section class="relative h-[30vh] min-h-[200px] overflow-hidden">
        <img
            src={artist.imageUrl}
            alt={artist.name}
            class="absolute inset-0 h-full w-full object-cover"
            loading="eager"
        />
        <div class="absolute inset-0 bg-black/30"></div>
    </section>

    <section class="bg-midnight py-24 text-white min-h-screen">
        <div class="container mx-auto px-4 max-w-6xl">
            <div class="mb-12">
                <a href={`${base}programma`} class="text-sky font-bold flex items-center gap-2 hover:text-magenta transition-colors w-fit">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                    </svg>
                    Terug naar programma
                </a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
                <div class="aspect-square overflow-hidden rounded-[2.5rem] bg-plum-800 shadow-2xl">
                    <img
                        src={artist.imageUrl}
                        alt={artist.name}
                        class="h-full w-full object-cover"
                        loading="lazy"
                    />
                </div>

                <div class="flex flex-col h-full">
                    <h1 class="font-display text-5xl sm:text-6xl md:text-8xl font-bold mb-8 tracking-tight text-sky leading-[0.9]">
                        {artist.name}
                    </h1>

                    <div class="flex flex-wrap gap-4 mb-10">
                        {artist.performances.length > 0 ? (
                            artist.performances.map((performance) => (
                                <>
                                    <div class="flex items-center gap-2 bg-plum/50 px-6 py-3 rounded-full border border-plum-300/30 backdrop-blur-sm">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-magenta">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                                        </svg>
                                        <span class="font-bold text-xl uppercase tracking-wider">
                                            {performance.day} - {performance.time || 't.b.d.'}
                                        </span>
                                    </div>
                                    {performance.podium && (
                                        <div class="flex items-center gap-2 bg-plum/50 px-6 py-3 rounded-full border border-plum-300/30 backdrop-blur-sm">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-magenta">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                                            </svg>
                                            <span class="font-bold text-xl uppercase tracking-wider">
                                                {performance.podium}
                                            </span>
                                        </div>
                                    )}
                                </>
                            ))
                        ) : (
                            <>
                                <div class="flex items-center gap-2 bg-plum/50 px-6 py-3 rounded-full border border-plum-300/30 backdrop-blur-sm">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-magenta">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    <span class="font-bold text-xl uppercase tracking-wider">Tijd volgt</span>
                                </div>
                                {artist.podium && (
                                    <div class="flex items-center gap-2 bg-plum/50 px-6 py-3 rounded-full border border-plum-300/30 backdrop-blur-sm">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-magenta">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                                        </svg>
                                        <span class="font-bold text-xl uppercase tracking-wider">
                                            {artist.podium}
                                        </span>
                                    </div>
                                )}
                            </>
                        )}
                    </div>

                    <div class="prose prose-xl prose-invert max-w-none mb-12 flex-grow">
                        <p class="text-2xl leading-relaxed text-white/90 font-medium">
                            {artist.description}
                        </p>
                    </div>

                    <div class="flex flex-wrap gap-4 mt-auto">
                        {artist.youtubeLink && (
                            <Button href={artist.youtubeLink} variant="primary" size="lg" class="w-full md:w-auto" target="_blank" rel="noopener noreferrer">
                                <span class="flex items-center gap-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-6 h-6">
                                        <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/>
                                    </svg>
                                    Bekijk op YouTube
                                </span>
                            </Button>
                        )}

                        {artist.spotifyLink && (
                            <Button href={artist.spotifyLink} variant="outline" color="white" size="lg" class="w-full md:w-auto" target="_blank" rel="noopener noreferrer">
                                <span class="flex items-center gap-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-6 h-6">
                                        <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.508 17.302c-.218.358-.684.472-1.042.254-2.88-1.76-6.505-2.16-10.772-1.184-.41.094-.82-.164-.914-.574-.094-.41.164-.82.574-.914 4.672-1.07 8.67-.61 11.898 1.36.358.218.472.684.254 1.058zm1.47-3.254c-.276.448-.86.586-1.308.31-3.298-2.028-8.324-2.616-12.23-1.428-.504.154-1.04-.136-1.194-.64-.154-.504.136-1.04.64-1.194 4.464-1.354 10.004-.7 13.78 1.628.448.276.586.86.31 1.314zm.126-3.416c-3.956-2.35-10.474-2.566-14.264-1.414-.606.184-1.25-.164-1.434-.77-.184-.606.164-1.25.77-1.434 4.35-1.32 11.542-1.062 16.1 1.644.544.324.72 1.026.396 1.57-.324.544-1.026.72-1.57.396z"/>
                                    </svg>
                                    Luister op Spotify
                                </span>
                            </Button>
                        )}
                    </div>
                </div>
            </div>
        </div>
    </section>
    <TicketsCTA variant="lime" />
</Layout>
