---
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import EasterEggs from "../components/visuals/EasterEggs.astro";
import MackerelChatbot from "../components/visuals/MackerelChatbot.astro";
import CookieConsent from "../components/ui/CookieConsent.astro";
import "../styles/global.css";
import fetchApi from "../lib/strapi";

interface StrapiGlobal {
	siteName: string;
	siteDescription: string;
	showTicketButton: boolean;
	currentYear: number;
	favicon: {
		url: string;
		mime: string;
	} | null;
	defaultSeo: {
		metaTitle: string;
		metaDescription: string;
		shareImage: {
			url: string;
			width: number;
			height: number;
			alternativeText: string | null;
		};
	};
	attributes?: any;
}

const globalData = await fetchApi<StrapiGlobal>({
	endpoint: 'global',
	wrappedByKey: 'data',
	query: {
		'populate[defaultSeo][populate]': '*',
		'populate[favicon][populate]': '*',
	},
});

const global = globalData?.attributes ?? globalData;

const siteName = global?.siteName ?? "Loungefest | Noordwijkerhout | Comomeer";
const siteDescription = global?.siteDescription ?? "Zin in het gezelligste feestje van de Bollenstreek? Kom naar Loungefest! Ontdek nieuwe bands, dans bij de lola's en beleef een onvergetelijk weekend. Mis het niet en koop nu je kaarten.";
const showTicketButton = global?.showTicketButton ?? true;
const currentYear = global?.currentYear ?? new Date().getFullYear();
const favicon = global?.favicon;
const defaultSeo = global?.defaultSeo;
const metaTitle = defaultSeo?.metaTitle ?? siteName;
const metaDescription = defaultSeo?.metaDescription ?? siteDescription;
const shareImage = defaultSeo?.shareImage;

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---
<!doctype html>
<html lang="nl">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		{favicon
			? <link rel="icon" type={favicon.mime} href={favicon.url} />
			: <>
				<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
				<link rel="icon" href={`${base}favicon.ico`} />
			</>
		}
		<meta name="generator" content={Astro.generator} />
		<title>{metaTitle}</title>
		<meta name="description" content={metaDescription} />
		<meta property="og:title" content={metaTitle} />
		<meta property="og:description" content={metaDescription} />
		<meta property="og:type" content="website" />
		{shareImage && <meta property="og:image" content={shareImage.url} />}
		{shareImage && <meta property="og:image:width" content={String(shareImage.width)} />}
		{shareImage && <meta property="og:image:height" content={String(shareImage.height)} />}
		{shareImage?.alternativeText && <meta property="og:image:alt" content={shareImage.alternativeText} />}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={metaTitle} />
		<meta name="twitter:description" content={metaDescription} />
		{shareImage && <meta name="twitter:image" content={shareImage.url} />}
		<link rel="preload" as="font" type="font/woff2" href="/fonts/ClashDisplay-Semibold.woff2" crossorigin />
		<link rel="preload" as="font" type="font/woff2" href="/fonts/ClashDisplay-Bold.woff2" crossorigin />
		<link rel="preload" as="font" type="font/woff2" href="/fonts/ClashDisplay-Medium.woff2" crossorigin />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Mulish:ital,wght@0,200..1000;1,200..1000&display=swap" />
	</head>
	<body class="flex flex-col min-h-screen">
		<Header showTicketButton={showTicketButton} />
		<main class="flex-grow">
			<slot />
		</main>
		<Footer showTicketButton={showTicketButton} />
		<EasterEggs />
		<MackerelChatbot />
		<CookieConsent />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
	}
</style>
