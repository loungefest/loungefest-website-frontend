---
import rawSvg from '../../assets/loungefest-logo-block.svg?raw';

interface Props {
	color?: string;
	secondaryColor?: string;
	class?: string;
	[key: string]: any;
}

const { color, secondaryColor = 'plum', class: className, ...rest } = Astro.props;

// Helper to resolve color names (like 'plum') to Tailwind theme colors
const resolveColor = (val: string) => {
	if (!val || val === 'currentColor' || val.startsWith('#') || val.startsWith('var(') || val.startsWith('rgb') || val.startsWith('hsl')) {
		return val;
	}
	return `var(--color-${val}, ${val})`;
};

const resolvedColor = color ? resolveColor(color) : undefined;
const resolvedSecondaryColor = resolveColor(secondaryColor);

// 1. Make IDs unique to avoid collisions
const id = Math.random().toString(36).substring(2, 8);
let svg = rawSvg
	.replace(/id="([^"]+)"/g, (_, p1) => `id="${p1}-${id}"`)
	.replace(/url\(#([^)]+)\)/g, (_, p1) => `url(#${p1}-${id})`);

// 2. Handle colors
// Replace hardcoded pink with currentColor
svg = svg.replace(/fill="#e84abe"/g, 'fill="currentColor"');
// Replace hardcoded background block with a CSS variable
svg = svg.replace(/fill="#6c0f53"/g, 'fill="var(--loungefest-secondary-color)"');

// 3. Ensure responsive sizing
svg = svg.replace(/width="[0-9.]+"/, 'width="100%"')
	 .replace(/height="[0-9.]+"/, 'height="100%"');
---

<span
	class:list={['inline-block loungefest-logo-block-container', className]}
	style={{
		color: resolvedColor,
		'--loungefest-secondary-color': resolvedSecondaryColor
	}}
	role="img"
	{...rest}
	set:html={svg}
/>

<style is:global>
	.loungefest-logo-block-container svg {
		width: 100%;
		height: 100%;
		display: block;
	}
</style>
