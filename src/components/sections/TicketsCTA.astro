---
import Button from '../ui/Button.astro';
import LoungefestIcon from '../logo/LoungefestIcon.astro';

interface Props {
	title?: string;
	description?: string;
	buttonText?: string;
	variant?: 'sky' | 'midnight' | 'plum' | 'magenta' | 'sand' | 'lime' | 'bronze' | 'white';
}

const { 
    title = "Zorg dat je erbij bent!",
    description = "Scoor nu je tickets voor Loungefest en mis het meest relaxte festival van de Bollenstreek niet.",
    buttonText = "Koop Tickets",
    variant = "magenta"
} = Astro.props;

const variants = {
    sky: {
        bg: 'bg-sky',
        text: 'text-white',
        icon: 'white',
        button: 'white'
    },
    midnight: {
        bg: 'bg-midnight',
        text: 'text-white',
        icon: 'white',
        button: 'white'
    },
    plum: {
        bg: 'bg-plum',
        text: 'text-white',
        icon: 'white',
        button: 'white'
    },
    magenta: {
        bg: 'bg-magenta',
        text: 'text-white',
        icon: 'white',
        button: 'white'
    },
    sand: {
        bg: 'bg-sand',
        text: 'text-plum',
        icon: 'plum',
        button: 'plum'
    },
    lime: {
        bg: 'bg-lime',
        text: 'text-plum',
        icon: 'plum',
        button: 'plum'
    },
    bronze: {
        bg: 'bg-bronze',
        text: 'text-white',
        icon: 'white',
        button: 'white'
    },
    white: {
        bg: 'bg-white',
        text: 'text-plum',
        icon: 'plum',
        button: 'plum'
    }
};

const styles = variants[variant] || variants.magenta;
---

<section class={`relative ${styles.bg} py-24 overflow-hidden`}>
    <!-- Decorative Icon Background -->
    <div class="absolute -right-20 -top-20 h-64 w-64 opacity-20 -rotate-12 pointer-events-none select-none">
        <LoungefestIcon color={styles.icon} class="h-full w-full" />
    </div>

    <div class="container relative z-10 mx-auto px-4">
        <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center justify-between gap-12 md:gap-16">
            <div class="flex-1 text-center md:text-left">
                <h2 class={`font-display font-bold text-5xl md:text-7xl mb-6 ${styles.text} tracking-tight`}>
                    {title}
                </h2>
                <p class={`${styles.text} text-xl md:text-2xl font-medium leading-relaxed max-w-xl`}>
                    {description}
                </p>
            </div>

            <div class="w-full md:w-auto shrink-0">
                <Button href="/tickets" variant={styles.button as any} size="xl" class="w-full md:w-auto">
                    {buttonText}
                </Button>
            </div>
        </div>
    </div>
</section>
