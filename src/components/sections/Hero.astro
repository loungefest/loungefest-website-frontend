---
import LoungefestLogoBlock from '../logo/LoungefestLogoBlock.astro';
import Button from '../ui/Button.astro';
---

<section class="relative min-h-[calc(100vh-6rem)] flex items-center justify-center overflow-hidden py-16">
    <!-- Background Image -->
    <div class="absolute inset-0 z-0">
        <img
            src="/images/lf-hero.jpg"
            alt="Loungefest Hero Background"
            class="w-full h-full object-cover"
        />
        <!-- Slightly darken the background to ensure text readability -->
        <div class="absolute inset-0 bg-black/10"></div>
    </div>

    <!-- Content -->
    <div class="container relative z-10 mx-auto px-4 flex flex-col items-start justify-center">
        <div class="flex flex-col items-center text-center text-white max-w-3xl">
            <!-- Logo -->
            <div class="mb-8 w-full max-w-[400px]">
                <LoungefestLogoBlock
                    color="magenta"
                    secondaryColor="plum"
                    class="w-full h-auto drop-shadow-2xl"
                />
            </div>

            <!-- Date -->
            <h1 class="font-display font-bold text-6xl md:text-8xl mb-2 text-magenta drop-shadow-lg tracking-tight">
                17 & 18 juli 2026
            </h1>

            <!-- Location -->
            <p class="font-display font-medium text-2xl md:text-3xl mb-8 drop-shadow-md tracking-wide">
                Oosterduinse Meer - Noordwijkerhout
            </p>

            <!-- Description text -->
            <p class="text-lg md:text-xl mb-12 leading-relaxed drop-shadow-md font-sans font-medium">
                Welkom bij Loungefest, hét festival waar muziek, sfeer en gezelligheid samenkomen in het hart van Noordwijkerhout! Laat je meevoeren door relaxte loungemuziek, zomerse beats en live acts terwijl je geniet van een ongedwongen festivalsfeer.
            </p>

            <!-- Call to Action -->
            <Button
                href="/tickets"
                variant="primary"
                size="xl"
            >
                Tickets kopen
            </Button>
        </div>
    </div>
</section>

<style>
    /* Add smooth transitions and subtle animations if needed */
    section {
        background-color: var(--color-plum);
    }
</style>
