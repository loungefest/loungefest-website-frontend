---
import LoungefestIcon from '../logo/LoungefestIcon.astro';
import Button from '../ui/Button.astro';
import fetchApi from '../../lib/strapi';

interface StrapiGlobal {
    showTicketButton: boolean;
    attributes?: any;
}

const globalData = await fetchApi<StrapiGlobal>({
    endpoint: 'global',
    wrappedByKey: 'data',
});

const global = globalData?.attributes ?? globalData;
const showTicketButton = global?.showTicketButton ?? true;
---

<section class="relative bg-midnight py-24 overflow-hidden flex flex-col items-center">
    <!-- Background Visual (Feather) -->
    <div class="absolute -right-32 -bottom-24 h-[120%] w-[70%] opacity-20 select-none pointer-events-none">
        <LoungefestIcon
            color="sky"
            class="h-full w-full rotate-[-10deg] object-contain object-right"
        />
    </div>

    <div class="container relative z-10 px-4 flex flex-col items-center text-center">
        <!-- Heading -->
        <h2 class="font-display font-bold text-5xl md:text-7xl mb-16 text-sky-400 tracking-tight">
            Alvast warmdraaien?
        </h2>

        <!-- Players -->
        <div class="w-full max-w-2xl flex flex-col gap-10 mb-16">

            <!-- Spotify Player -->
            <div class="cookie-embed w-full flex flex-col items-center gap-12">
                <div class="cookie-placeholder flex h-[352px] w-full flex-col items-center justify-center gap-3 rounded-xl border border-plum-700/40 bg-plum-900/50 text-center text-white/60 text-sm px-6">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-10 h-10 opacity-40">
                        <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.508 17.302c-.218.358-.684.472-1.042.254-2.88-1.76-6.505-2.16-10.772-1.184-.41.094-.82-.164-.914-.574-.094-.41.164-.82.574-.914 4.672-1.07 8.67-.61 11.898 1.36.358.218.472.684.254 1.058zm1.47-3.254c-.276.448-.86.586-1.308.31-3.298-2.028-8.324-2.616-12.23-1.428-.504.154-1.04-.136-1.194-.64-.154-.504.136-1.04.64-1.194 4.464-1.354 10.004-.7 13.78 1.628.448.276.586.86.31 1.314zm.126-3.416c-3.956-2.35-10.474-2.566-14.264-1.414-.606.184-1.25-.164-1.434-.77-.184-.606.164-1.25.77-1.434 4.35-1.32 11.542-1.062 16.1 1.644.544.324.72 1.026.396 1.57-.324.544-1.026.72-1.57.396z"/>
                    </svg>
                    <span>Accepteer cookies om de Spotify playlist te laden.</span>
                    <button data-cookie-accept class="mt-1 rounded-xl bg-lime px-4 py-2 text-sm font-bold text-plum cursor-pointer transition-opacity hover:opacity-90">
                        Cookies accepteren
                    </button>
                </div>
                <iframe
                    title="Loungefest Spotify afspeellijst"
                    data-testid="embed-iframe"
                    style="border-radius:12px;display:none"
                    data-cookie-src="https://open.spotify.com/embed/playlist/4IEF27mKX6YWBsStjMIBeP?utm_source=generator"
                    width="100%" height="352"
                    frameBorder="0"
                    allowfullscreen=""
                    allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                    loading="lazy"
                ></iframe>
            </div>

            <!-- SoundCloud Player -->
            <div class="cookie-embed w-full flex flex-col items-center gap-12">
                <div class="cookie-placeholder flex h-[300px] w-full flex-col items-center justify-center gap-3 rounded-xl border border-plum-700/40 bg-plum-900/50 text-center text-white/60 text-sm px-6">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-10 h-10 opacity-40">
                        <path d="M1.175 12.225c-.056 0-.112.007-.168.02a.75.75 0 0 0-.575.73l-.432 4.153.432 4.084a.75.75 0 0 0 .743.67c.4 0 .73-.312.743-.712l.49-4.042-.49-4.19a.743.743 0 0 0-.743-.713zm2.24-1.68c-.069 0-.138.009-.206.027a.912.912 0 0 0-.694.884l-.496 5.576.496 5.34a.912.912 0 0 0 .9.826c.497 0 .905-.4.912-.898l.562-5.268-.562-5.65a.912.912 0 0 0-.912-.837zm2.41-.61c-.083 0-.166.01-.247.033a1.08 1.08 0 0 0-.82 1.047l-.557 6.217.557 5.97c.015.578.49 1.04 1.067 1.04.578 0 1.052-.461 1.067-1.04l.632-5.97-.632-6.29a1.068 1.068 0 0 0-1.067-1.007zm2.42-.27c-.097 0-.194.013-.288.038a1.25 1.25 0 0 0-.952 1.213l-.614 6.487.614 6.163c.017.672.568 1.21 1.24 1.21.672 0 1.224-.538 1.24-1.21l.697-6.163-.697-6.55a1.24 1.24 0 0 0-1.24-1.188zm9.568-.1a5.377 5.377 0 0 0-1.088.112 7.368 7.368 0 0 0-7.323-6.59 7.37 7.37 0 0 0-2.698.513v13.1c0 .766.617 1.39 1.383 1.406h9.726a3.483 3.483 0 0 0 3.483-3.483 3.483 3.483 0 0 0-3.483-3.058z"/>
                    </svg>
                    <span>Accepteer cookies om de SoundCloud playlist te laden.</span>
                    <button data-cookie-accept class="mt-1 rounded-xl bg-lime px-4 py-2 text-sm font-bold text-plum cursor-pointer transition-opacity hover:opacity-90">
                        Cookies accepteren
                    </button>
                </div>
                <iframe
                    title="Loungefest SoundCloud afspeellijst"
                    style="display:none"
                    data-cookie-src="https://w.soundcloud.com/player/?url=https%3A//api.soundcloud.com/playlists/soundcloud%253Aplaylists%253A2209695410&color=%23ff5500&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true&visual=true"
                    width="100%"
                    height="300"
                    scrolling="no"
                    frameborder="no"
                    allow="autoplay"
                ></iframe>
            </div>

        </div>

        <!-- CTA Button -->
        {showTicketButton && (
            <Button
                href="/tickets"
                variant="outline"
                color="white"
                size="md"
                class="min-w-[240px]"
            >
                Kaarten LF 2026
            </Button>
        )}
    </div>
</section>
