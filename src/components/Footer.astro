---
import loungefestLogo from '../assets/loungefest-icon.svg';
---

<footer class="bg-plum text-white relative overflow-hidden py-24 px-12 md:px-24">
    <!-- Background Shapes -->
    <div class="absolute -left-20 bottom-0 w-80 h-80 bg-magenta/30 rounded-full blur-3xl -z-10"></div>
    <div class="absolute left-1/4 -bottom-20 w-96 h-96 bg-magenta/20 rounded-full blur-[100px] -z-10"></div>
    <div class="absolute -right-20 -top-20 w-80 h-80 bg-magenta/40 rounded-full blur-3xl -z-10"></div>

    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-start justify-between gap-12 relative z-10">
        <!-- Logo Section -->
        <div class="flex-shrink-0">
            <a href="/" class="hover:scale-105 transition-transform duration-300 block">
                <img src={loungefestLogo.src} alt="Loungefest Logo" class="h-32 md:h-40 w-auto" />
            </a>
        </div>

        <!-- Links Columns -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-12 md:gap-24">
            <!-- Contact -->
            <div class="flex flex-col gap-6">
                <h3 class="font-display font-bold text-2xl uppercase tracking-wider">Contact</h3>
                <a href="mailto:info@loungefest.nl" class="font-sans text-lg hover:opacity-70 transition-opacity">info@loungefest.nl</a>
            </div>

            <!-- Socials -->
            <div class="flex flex-col gap-6">
                <h3 class="font-display font-bold text-2xl uppercase tracking-wider">Socials</h3>
                <ul class="flex flex-col gap-4">
                    <li><a href="https://instagram.com" class="font-sans text-lg hover:opacity-70 transition-opacity">Instagram</a></li>
                    <li><a href="https://facebook.com" class="font-sans text-lg hover:opacity-70 transition-opacity">Facebook</a></li>
                    <li><a href="https://spotify.com" class="font-sans text-lg hover:opacity-70 transition-opacity">Spotify</a></li>
                </ul>
            </div>

            <!-- Nieuws -->
            <div class="flex flex-col gap-6">
                <h3 class="font-display font-bold text-2xl uppercase tracking-wider">Nieuws</h3>
                <ul class="flex flex-col gap-8">
                    <li><a href="/nieuwsbrief" class="font-sans text-lg hover:opacity-70 transition-opacity">Nieuwsbrief</a></li>
                    <li>
                        <a href="/tickets" class="inline-block border-2 border-white rounded-full px-8 py-2 font-display font-bold text-xl hover:bg-white hover:text-plum transition-all duration-300">
                            Tickets kopen
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</footer>

<style>
    /* Adding some organic feel to the background if needed, but Tailwind blur/opacity usually handles it well */
    footer {
        /* Ensuring it's at the bottom if the page is short */
        margin-top: auto;
    }
</style>
