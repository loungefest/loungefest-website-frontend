---
import makreelImg from '../../assets/images/makreel.png';
---

<div id="mackerel-chatbot" data-src={makreelImg.src}>
    <!-- Toggle button (fish head) -->
    <button id="chatbot-toggle" aria-label="Chat met de Makreel" title="Stel de Makreel een vraag">
        <div class="fish-head-crop">
            <img src={makreelImg.src} alt="Makreel" />
        </div>
        <span class="online-dot"></span>
    </button>

    <!-- Chat window -->
    <div id="chat-window" aria-hidden="true">
        <div class="chat-header">
            <div class="header-avatar">
                <img src={makreelImg.src} alt="Makreel" />
            </div>
            <div class="header-info">
                <strong>Makreel Assistent</strong>
                <span>● Online</span>
            </div>
            <button id="chat-close" aria-label="Sluit chat">✕</button>
        </div>

        <div id="chat-messages" role="log" aria-live="polite">
            <div class="msg bot">
                <div class="bubble">Blub blub... hoi! Ik ben de Loungefest Makreel. Waarmee kan ik je helpen? 🐟</div>
            </div>
        </div>

        <div class="chat-input-row">
            <input type="text" id="chat-input" placeholder="Stel een vraag..." autocomplete="off" maxlength="200" />
            <button id="chat-send" aria-label="Verstuur">&#10148;</button>
        </div>
    </div>
</div>

<style is:global>
    #mackerel-chatbot {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 9998;
        display: flex;
        flex-direction: column-reverse;
        align-items: flex-end;
        gap: 12px;
        pointer-events: none;
    }

    /* ── Toggle button ── */
    #chatbot-toggle {
        position: relative;
        pointer-events: auto;
        width: 68px;
        height: 68px;
        border-radius: 50%;
        border: 3px solid #fff;
        background: #1a1a2e;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
        cursor: pointer;
        padding: 0;
        transition: transform 0.2s, box-shadow 0.2s;
        animation: chatbot-pop-in 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        animation-delay: 2s;
        transform: translateY(120px);
    }

    @keyframes chatbot-pop-in {
        from { transform: translateY(120px); opacity: 0; }
        to   { transform: translateY(0);     opacity: 1; }
    }

    #chatbot-toggle:hover {
        transform: scale(1.08);
        box-shadow: 0 6px 28px rgba(0, 0, 0, 0.5);
    }

    #chatbot-toggle:active {
        transform: scale(0.96);
    }

    .fish-head-crop {
        width: 100%;
        height: 100%;
        overflow: hidden;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .fish-head-crop img {
        /* Show just the head — fish faces left in natural orientation */
        width: 256px;
        max-width: 256px;
        height: auto;
        transform: translateX(-96px) translateY(5px);
        pointer-events: none;
        user-select: none;
        /* subtle bob */
        animation: head-bob 2s ease-in-out infinite;
    }

    @keyframes head-bob {
        0%, 100% { transform: translateX(-96px) translateY(5px) rotate(-3deg); }
        50%       { transform: translateX(-96px) translateY(-2px) rotate(3deg); }
    }

    .online-dot {
        position: absolute;
        bottom: 2px;
        right: 2px;
        width: 12px;
        height: 12px;
        background: #22c55e;
        border-radius: 50%;
        border: 2px solid #fff;
        animation: pulse-dot 2s ease-in-out infinite;
    }

    @keyframes pulse-dot {
        0%, 100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.5); }
        50%       { box-shadow: 0 0 0 5px rgba(34, 197, 94, 0); }
    }

    /* ── Chat window ── */
    #chat-window {
        width: 300px;
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 8px 40px rgba(0, 0, 0, 0.25);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transform-origin: bottom right;
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.25s ease;
    }

    #chat-window[aria-hidden="true"] {
        transform: scale(0.7) translateY(20px);
        opacity: 0;
        pointer-events: none;
    }

    #chat-window[aria-hidden="false"] {
        transform: scale(1) translateY(0);
        opacity: 1;
        pointer-events: auto;
    }

    /* Header */
    .chat-header {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        background: #1a1a2e;
        color: #fff;
    }

    .header-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        overflow: hidden;
        flex-shrink: 0;
        background: #2d2d44;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .header-avatar img {
        width: 128px;
        max-width: 128px;
        height: auto;
        transform: translateX(-48px);
        pointer-events: none;
    }

    .header-info {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 1px;
    }

    .header-info strong {
        font-size: 13px;
        line-height: 1;
    }

    .header-info span {
        font-size: 11px;
        color: #22c55e;
        line-height: 1;
    }

    #chat-close {
        background: none;
        border: none;
        color: rgba(255,255,255,0.7);
        font-size: 16px;
        cursor: pointer;
        padding: 2px 4px;
        line-height: 1;
        transition: color 0.15s;
    }

    #chat-close:hover {
        color: #fff;
    }

    /* Messages */
    #chat-messages {
        flex: 1;
        padding: 14px 12px;
        overflow-y: auto;
        max-height: 280px;
        min-height: 120px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        background: #f5f5f7;
    }

    .msg {
        display: flex;
    }

    .msg.user {
        justify-content: flex-end;
    }

    .msg.bot {
        justify-content: flex-start;
    }

    .bubble {
        max-width: 80%;
        padding: 8px 12px;
        border-radius: 14px;
        font-size: 13px;
        line-height: 1.45;
        word-break: break-word;
    }

    .msg.bot .bubble {
        background: #ffffff;
        color: #1a1a2e;
        border-bottom-left-radius: 4px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.08);
    }

    .msg.user .bubble {
        background: #1a1a2e;
        color: #fff;
        border-bottom-right-radius: 4px;
    }

    /* Typing indicator */
    .typing-dots {
        display: flex;
        gap: 4px;
        padding: 4px 2px;
        align-items: center;
    }

    .typing-dots span {
        width: 7px;
        height: 7px;
        background: #aaa;
        border-radius: 50%;
        animation: typing-bounce 1s ease-in-out infinite;
    }

    .typing-dots span:nth-child(2) { animation-delay: 0.15s; }
    .typing-dots span:nth-child(3) { animation-delay: 0.30s; }

    @keyframes typing-bounce {
        0%, 80%, 100% { transform: translateY(0); }
        40%            { transform: translateY(-6px); }
    }

    /* Input row */
    .chat-input-row {
        display: flex;
        padding: 10px 12px;
        gap: 8px;
        border-top: 1px solid #e5e5ea;
        background: #fff;
    }

    #chat-input {
        flex: 1;
        border: 1px solid #d1d1d6;
        border-radius: 20px;
        padding: 7px 14px;
        font-size: 13px;
        outline: none;
        background: #f5f5f7;
        transition: border-color 0.15s;
    }

    #chat-input:focus {
        border-color: #1a1a2e;
    }

    #chat-send {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: #1a1a2e;
        color: #fff;
        border: none;
        font-size: 16px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: background 0.15s, transform 0.1s;
    }

    #chat-send:hover  { background: #2d2d44; }
    #chat-send:active { transform: scale(0.9); }
</style>

<script>
    const toggle   = document.getElementById('chatbot-toggle');
    const chatWin  = document.getElementById('chat-window');
    const closeBtn = document.getElementById('chat-close');
    const input    = document.getElementById('chat-input') as HTMLInputElement;
    const sendBtn  = document.getElementById('chat-send');
    const messages = document.getElementById('chat-messages');

    function openChat() {
        if (!chatWin) return;
        chatWin.setAttribute('aria-hidden', 'false');
        input?.focus();
    }

    function closeChat() {
        if (!chatWin) return;
        chatWin.setAttribute('aria-hidden', 'true');
    }

    toggle?.addEventListener('click', () => {
        const isOpen = chatWin?.getAttribute('aria-hidden') === 'false';
        isOpen ? closeChat() : openChat();
    });

    closeBtn?.addEventListener('click', closeChat);

    // Responses for questions (ends with ? or starts with question word)
    const questionResponses = [
        "Weet ik niet 🤷",
        "Geen idee. Ik ben een vis.",
        "Blub blub... ik heb daar geen antwoord op.",
        "Vraag het maar aan iemand die geen kieuwen heeft.",
        "Ik weet het echt niet, sorry.",
        "Hmm... nee. Geen idee.",
        "Dat gaat mijn petje te boven. Of mijn vin.",
        "Ik ben een makreel, niet een encyclopedie.",
        "Weet ik niet. Weet ik nooit.",
        "Als ik het wist, zou ik het zeggen. Maar ik weet het niet.",
        "Ik heb een hersenen ter grootte van een erwt. Dus nee.",
        "Misschien weet Ben het?",
        "Ik weet het niet, maar ik weet wel dat je een goede vraag hebt gesteld.",
        // Klantenservice-vis
        "Welkom bij de Loungefest Klantenser-vis. Voor vragen over kaarten, druk 1. Voor vragen waarop ik het antwoord weet, druk... eigenlijk bestaat die optie niet.",
        "U spreekt met de klantenser-vis. Uw vraag is belangrijk voor ons. Helaas weet ik het antwoord niet. Fijne dag verder. 🐟",
        "Alle medewerkers zijn momenteel in het water. Uw wachttijd is onbepaald.",
        "Klantenser-vis Makreel hier. Ik verbind u graag door naar een collega die het ook niet weet.",
        "Uw tevredenheid is onze prioriteit. Helaas kan ik u niet helpen. Heeft u verder nog vragen die ik ook niet kan beantwoorden?",
        "Bedankt voor uw geduld. Na deze toon wordt u niet geholpen. *piep*",
        "Ik heb uw vraag genoteerd en doorgestuurd naar een afdeling die er niks mee doet.",
        // Aan de lijn
        "Als u een echte makreel aan de lijn wilt krijgen, raad ik een hengel aan. 🎣",
        "U heeft een makreel aan de lijn! Helaas weet deze makreel het ook niet.",
        "Voor een echte makreel aan de lijn: ga naar het Comomeer met een dobber en wat aas. Succes.",
        "Ik ben wél aan de lijn, maar ik heb geen antwoord. Technisch gezien een succes.",
        "U spreekt met de enige makreel die ooit vrijwillig de telefoon heeft opgenomen. En ik weet het niet.",
    ];

    // Responses for statements / greetings / small talk
    const statementResponses = [
        "Blub.",
        "Interessant. Ik zwem gewoon door.",
        "Oke. En verder?",
        "Dat zal best. Ik ben een vis.",
        "Noted. Blub.",
        "Ik hoor je. Ik begrijp je niet, maar ik hoor je.",
        "Hm. Ik weet niet wat ik daarmee moet.",
        "Dank voor de mededeling. Ik doe er niks mee.",
        "Als reactie hierop: blub blub.",
        "Ik knik meelevend, maar ik heb geen nek.",
        "Boeiend. Ik zwem inmiddels al drie keer in kringetjes.",
        "Fijn dat je dat deelt. Echt.",
        "Ik sla dit op in mijn geheugen. Dat duurt nog ongeveer drie seconden.",
    ];

    // Greetings get a special first response
    const greetingPatterns = /^(hoi|hallo|hey|hi|goedemorgen|goedemiddag|goedenavond|dag|heej|hé|he)\b/i;
    const questionPatterns = /^(wie|wat|waar|wanneer|waarom|hoe|welke|welk|hoeveel|mag|kan|is|zijn|heeft|hebben|wil|weet|ken)\b|\?/i;

    let greeted = false;

    const greetingResponses = [
        "Hoi! Blub blub. Stel gerust een vraag die ik niet kan beantwoorden. 🐟",
        "Hallo! Ik ben de Loungefest Klantenser-vis. Ik weet nergens iets van, maar ik luister wel.",
        "Hey! Fijn dat je er bent. Ik helaas niet echt, want ik ben een vis op een website.",
    ];

    function pickRandom(arr: string[]): string {
        return arr[Math.floor(Math.random() * arr.length)];
    }

    function getResponse(text: string): string {
        const trimmed = text.trim();

        if (!greeted && greetingPatterns.test(trimmed)) {
            greeted = true;
            return pickRandom(greetingResponses);
        }

        if (questionPatterns.test(trimmed)) {
            return pickRandom(questionResponses);
        }

        return pickRandom(statementResponses);
    }

    function addMessage(text: string, sender: 'user' | 'bot') {
        if (!messages) return;
        const msg = document.createElement('div');
        msg.className = `msg ${sender}`;
        const bubble = document.createElement('div');
        bubble.className = 'bubble';
        bubble.textContent = text;
        msg.appendChild(bubble);
        messages.appendChild(msg);
        messages.scrollTop = messages.scrollHeight;
    }

    function showTyping(): HTMLElement {
        if (!messages) return document.createElement('div');
        const msg = document.createElement('div');
        msg.className = 'msg bot typing-msg';
        const bubble = document.createElement('div');
        bubble.className = 'bubble';
        bubble.innerHTML = '<div class="typing-dots"><span></span><span></span><span></span></div>';
        msg.appendChild(bubble);
        messages.appendChild(msg);
        messages.scrollTop = messages.scrollHeight;
        return msg;
    }

    function handleSend() {
        const text = input?.value.trim();
        if (!text) return;
        addMessage(text, 'user');
        input.value = '';

        const typingEl = showTyping();
        const delay = 700 + Math.random() * 600;

        setTimeout(() => {
            typingEl.remove();
            addMessage(getResponse(text), 'bot');
        }, delay);
    }

    sendBtn?.addEventListener('click', handleSend);
    input?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') handleSend();
    });
</script>
