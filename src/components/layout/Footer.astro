---
import LoungefestLogo from '../logo/LoungefestLogo.astro';
import LavaLamp from '../visuals/LavaLamp.astro';
import Button from '../ui/Button.astro';
import fetchApi from '../../lib/strapi';

interface Props {
    showTicketButton?: boolean;
    minimal?: boolean;
}

const { showTicketButton = true, minimal = false } = Astro.props;

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

interface StrapiGlobal {
    currentYear: number;
}

const globalData = await fetchApi<StrapiGlobal>({
    endpoint: 'global',
    wrappedByKey: 'data',
});

const global = globalData?.attributes ?? globalData;
const currentYear = global?.currentYear ?? new Date().getFullYear();
---

{minimal ? (
<footer class="bg-plum text-white py-8 px-4">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4 text-white/60 font-sans text-sm">
        <p>Copyright © {currentYear} Stichting NYCE</p>
        <a href="mailto:info@loungefest.nl" class="hover:text-white transition-colors">info@loungefest.nl</a>
    </div>
</footer>
) : (
<footer class="bg-plum text-white relative overflow-hidden py-24 px-12 lg:px-24">
    <LavaLamp color="magenta" ballSize={4} numBalls={20} overflow={1000} responsive={true} />

    <div class="max-w-7xl mx-auto flex flex-col xl:flex-row items-start gap-12 xl:gap-24 relative z-10">
        <!-- Logo Section -->
        <div class="flex-shrink-0">
            <a href={base} class="hover:scale-105 transition-transform duration-300 block">
                <LoungefestLogo color="magenta" secondaryColor="white" aria-label="Loungefest Logo" />
            </a>
        </div>

        <!-- Links Columns -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-24 self-start w-fit">
            <!-- Navigatie -->
            <div class="flex flex-col gap-6">
                <h3 class="font-display font-bold text-2xl uppercase tracking-wider">Navigatie</h3>
                <ul class="flex flex-col gap-4">
                    <li><a href={`${base}programma`} class="font-sans text-lg hover:opacity-70 transition-opacity">Programma</a></li>
                    <li><a href={`${base}sponsors`} class="font-sans text-lg hover:opacity-70 transition-opacity">Sponsors</a></li>
                    <li><a href={`${base}ploegen`} class="font-sans text-lg hover:opacity-70 transition-opacity">Ploegen</a></li>
                    <li><a href={`${base}edities`} class="font-sans text-lg hover:opacity-70 transition-opacity">Edities</a></li>
                    <li><a href={`${base}info`} class="font-sans text-lg hover:opacity-70 transition-opacity">Info</a></li>
                    <li><a href={`${base}vacature`} class="font-sans text-lg hover:opacity-70 transition-opacity">Vacatures</a></li>
                    <li><a href="https://www.noordwijk.info/cultuur" target="_blank" rel="noopener noreferrer" class="font-sans text-lg hover:opacity-70 transition-opacity">Noordwijk cultuur</a></li>
                </ul>
            </div>

            <!-- Contact -->
            <div class="flex flex-col gap-6">
                <h3 class="font-display font-bold text-2xl uppercase tracking-wider">Contact</h3>
                <ul class="flex flex-col gap-4">
                    <li><a href="mailto:info@loungefest.nl" class="font-sans text-lg hover:opacity-70 transition-opacity">info@loungefest.nl</a></li>
                    <!--<li><a href="tel:0628883981" class="font-sans text-lg hover:opacity-70 transition-opacity">06-2888 3981</a></li>-->
                </ul>
            </div>

            <!-- Socials -->
            <div class="flex flex-col gap-6">
                <h3 class="font-display font-bold text-2xl uppercase tracking-wider">Socials</h3>
                <ul class="flex flex-col gap-4">
                    <li><a href="https://www.instagram.com/loungefest.nl/" target="_blank" rel="noopener noreferrer" class="font-sans text-lg hover:opacity-70 transition-opacity">Instagram</a></li>
                    <li><a href="https://www.facebook.com/loungefestnwh/" target="_blank" rel="noopener noreferrer" class="font-sans text-lg hover:opacity-70 transition-opacity">Facebook</a></li>
                    <li><a href="https://open.spotify.com/user/loungefest?si=a9c87644bf884c6a" target="_blank" rel="noopener noreferrer" class="font-sans text-lg hover:opacity-70 transition-opacity">Spotify</a></li>
                </ul>
            </div>

            {showTicketButton && (
                <div>
                    <Button href="/kaarten" variant="outline" size="lg">
                        Kaarten kopen
                    </Button>
                </div>
            )}
        </div>
    </div>

    <!-- Copyright Section -->
    <div class="max-w-7xl mx-auto mt-24 pt-8 border-t border-white/20 relative z-10 flex flex-col md:flex-row justify-between items-center gap-4 text-white/60 font-sans">
        <p>Copyright © {currentYear} Stichting NYCE</p>
    </div>
</footer>
)}

<style>
    /* Adding some organic feel to the background if needed, but Tailwind blur/opacity usually handles it well */
    footer {
        /* Ensuring it's at the bottom if the page is short */
        margin-top: auto;
    }
</style>
